# finops-mcp uses DefaultAzureCredential — if `az login` works, you need nothing here.
# Only set these for headless/CI auth with a service principal.

# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=

# Default subscription used when `scope` is omitted (optional convenience).
# AZURE_SUBSCRIPTION_ID=

# Gate for future write tools (draft_terraform_remediation, draft_github_issue).
# FINOPS_MCP_ALLOW_WRITES=0
